<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp"
    tools:ignore="MissingClass">

    <!-- Column 1: Machine Name -->
    <TextView android:id="@+id/tvMachine" android:layout_width="0dp"
        android:layout_height="wrap_content" android:layout_marginEnd="4dp" android:text="M1"
        app:layout_constraintEnd_toStartOf="@+id/tvTemp"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_weight="1.2" />

    <!-- Column 2: Temperature -->
    <TextView android:id="@+id/tvTemp" android:layout_width="0dp"
        android:layout_height="wrap_content" android:layout_marginEnd="4dp" android:text="25°C"
        app:layout_constraintEnd_toStartOf="@+id/tvSpeed"
        app:layout_constraintStart_toEndOf="@+id/tvMachine" app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_weight="0.8" />

    <!-- Column 3: Speed -->
    <TextView android:id="@+id/tvSpeed" android:layout_width="0dp"
        android:layout_height="wrap_content" android:layout_marginEnd="4dp" android:text="100"
        app:layout_constraintEnd_toStartOf="@+id/tvPower"
        app:layout_constraintStart_toEndOf="@+id/tvTemp" app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_weight="0.8" />

    <!-- Column 4: Power -->
    <TextView android:id="@+id/tvPower" android:layout_width="0dp"
        android:layout_height="wrap_content" android:layout_marginEnd="4dp" android:text="On"
        app:layout_constraintEnd_toStartOf="@+id/tvTimestamp"
        app:layout_constraintStart_toEndOf="@+id/tvSpeed" app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_weight="1" />

    <!-- Column 5: Timestamp -->
    <TextView android:id="@+id/tvTimestamp" android:layout_width="0dp"
        android:layout_height="wrap_content" android:text="12:00"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toEndOf="@+id/tvPower"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintHorizontal_weight="1.2" />

</androidx.constraintlayout.widget.ConstraintLayout>